const firstSections = {
{{#each firstSections}}
    "{{{project}}}": "{{{section}}}"{{#unless @last}},{{/unless}}
{{/each}}
};
const projectSlugs = Object.keys(firstSections);
const projectSlugsByLength = [...projectSlugs].sort((left, right) => right.length - left.length);
const projectOptions = Array.from(document.querySelectorAll("[data-project-option]"));
const sidebarCollapse = document.querySelector(".sidebar-collapse");
const sidebarCollapseLabel = document.querySelector("[data-sidebar-collapse-label]");
const sidebarToggle = document.querySelector(".sidebar-toggle");
const sidebarContent = document.querySelector(".sidebar-content");
const themeSwitcher = document.querySelector("[data-theme-switcher]");
const projectArticles = new Map(Array.from(document.querySelectorAll("article.guide-document[data-project]")).map((article) => [article.dataset.project, article]));
const projectSections = new Map(projectOptions.map((summary) => {
    const section = summary.closest("[data-project-nav]");
    return [section.dataset.projectNav, { section, summary, article: projectArticles.get(section.dataset.projectNav) }];
}));
const themeStorageKey = "theme";
const headingCache = new Map();
let activeSectionId = "";
let activeLink;
let scrollSpyFrame = 0;
let contentScrollFrame = 0;

function copyText(element) {
    let range;
    let selection;

    if (document.body.createTextRange) {
        range = document.body.createTextRange();
        range.moveToElementText(element);
        range.select();
    } else if (window.getSelection) {
        selection = window.getSelection();
        range = document.createRange();
        range.selectNodeContents(element);
        selection.removeAllRanges();
        selection.addRange(range);
    }

    document.execCommand("copy");
}

window.copyToClipboard = function copyToClipboard(element) {
    const source = element.parentNode?.previousElementSibling;
    if (source) {
        copyText(source);
    }
};

function storedTheme() {
    try {
        if (window.localStorage) {
            return localStorage.getItem(themeStorageKey);
        }
    } catch (e) {
        return null;
    }
    return null;
}

function preferredTheme() {
    const theme = storedTheme();
    if (theme === "dark" || theme === "light") {
        return theme;
    }
    if (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches) {
        return "dark";
    }
    return "light";
}

function applyTheme(theme, persist) {
    const dark = theme === "dark";
    document.body.classList.toggle("dark-mode", dark);
    if (themeSwitcher) {
        const label = dark ? "Switch to light theme" : "Switch to dark theme";
        themeSwitcher.setAttribute("aria-label", label);
        themeSwitcher.setAttribute("aria-pressed", String(dark));
        themeSwitcher.setAttribute("title", label);
    }
    try {
        if (persist && window.localStorage) {
            localStorage.setItem(themeStorageKey, dark ? "dark" : "light");
        }
    } catch (e) {
        return;
    }
}

function switchTheme(persist) {
    applyTheme(document.body.classList.contains("dark-mode") ? "light" : "dark", persist);
}

window.switchTheme = switchTheme;

function projectFromHash() {
    const hash = decodeURIComponent(window.location.hash.slice(1));
    return projectFromSectionId(hash);
}

function projectFromSectionId(sectionId) {
    return projectSlugsByLength.find((project) => sectionId.startsWith(project + "-"));
}

function sectionHeadings(project) {
    if (!headingCache.has(project)) {
        const data = projectSections.get(project);
        const tocSections = new Set(Array.from(data?.section.querySelectorAll("[data-section]") ?? []).map((link) => link.dataset.section));
        const article = data?.article;
        const headings = Array.from(article?.querySelectorAll("h1[id], h2[id], h3[id], h4[id], h5[id], h6[id]") ?? [])
            .filter((heading) => tocSections.has(heading.id));
        headingCache.set(project, headings);
    }
    return headingCache.get(project);
}

function activeSectionFromScroll() {
    const project = document.body.dataset.project;
    const headings = sectionHeadings(project);
    const topbarHeight = document.querySelector(".topbar")?.getBoundingClientRect().height ?? 0;
    const activationTop = topbarHeight + 24;
    let activeId = firstSections[project];
    for (const heading of headings) {
        if (heading.getBoundingClientRect().top <= activationTop) {
            activeId = heading.id;
        } else {
            break;
        }
    }
    return activeId;
}

function queueScrollSpy() {
    if (scrollSpyFrame) {
        return;
    }
    scrollSpyFrame = window.requestAnimationFrame(() => {
        scrollSpyFrame = 0;
        const nextActiveSectionId = activeSectionFromScroll();
        if (nextActiveSectionId && nextActiveSectionId !== activeSectionId) {
            refreshActiveLink(nextActiveSectionId);
        }
    });
}

function scrollProjectSubmenu(section) {
    const submenu = section?.querySelector(".toc-tree");
    if (!sidebarContent || !submenu) {
        return;
    }
    window.requestAnimationFrame(() => {
        const top = submenu.getBoundingClientRect().top - sidebarContent.getBoundingClientRect().top + sidebarContent.scrollTop;
        sidebarContent.scrollTo({
            top: Math.max(0, top),
            behavior: "auto"
        });
    });
}

function scrollToSectionNow(sectionId) {
    const target = document.getElementById(sectionId);
    if (!target) {
        return;
    }
    target.scrollIntoView({
        block: "start",
        behavior: "auto"
    });
    const topbarHeight = document.querySelector(".topbar")?.getBoundingClientRect().height ?? 0;
    const preferredTop = topbarHeight + 16;
    const targetTop = target.getBoundingClientRect().top;
    if (Math.abs(targetTop - preferredTop) <= 1) {
        return;
    }
    window.scrollBy({
        top: targetTop - preferredTop,
        behavior: "auto"
    });
}

function scrollToSection(sectionId) {
    if (contentScrollFrame) {
        window.cancelAnimationFrame(contentScrollFrame);
    }
    contentScrollFrame = window.requestAnimationFrame(() => {
        contentScrollFrame = window.requestAnimationFrame(() => {
            contentScrollFrame = 0;
            scrollToSectionNow(sectionId);
            refreshActiveLink(sectionId);
            queueScrollSpy();
        });
    });
}

function setProject(project, options) {
    const settings = options || {};
    if (!firstSections[project]) {
        project = projectSlugs[0];
    }
    const previousProject = document.body.dataset.project;
    const previous = projectSections.get(previousProject);
    const next = projectSections.get(project);
    document.body.dataset.project = project;

    if (previousProject !== project && previous) {
        if (previous.article) {
            previous.article.hidden = true;
        }
        previous.section.classList.remove("active");
        previous.section.open = false;
        previous.summary.setAttribute("aria-current", "false");
    }
    if (next) {
        if (next.article) {
            next.article.hidden = false;
        }
        next.section.classList.add("active");
        next.section.open = true;
        next.summary.setAttribute("aria-current", "true");
    }

    const firstSection = firstSections[project];
    if (settings.updateHash && (settings.forceHash || !projectFromHash())) {
        history.replaceState(null, "", "#" + firstSection);
    }
    refreshActiveLink(settings.scrollContent ? firstSection : undefined);
    if (settings.scrollContent) {
        scrollToSection(firstSection);
    } else {
        queueScrollSpy();
    }
    if (settings.scrollSubmenu && project !== previousProject) {
        scrollProjectSubmenu(next?.section);
    }
}

function refreshActiveLink(nextActiveSectionId) {
    const activeId = nextActiveSectionId || decodeURIComponent(window.location.hash.slice(1));
    if (activeLink && activeLink.dataset.section !== activeId) {
        activeLink.classList.remove("active");
        activeLink = undefined;
    }
    if (!activeId) {
        return;
    }
    const project = projectFromSectionId(activeId) || document.body.dataset.project;
    const nextLink = projectSections.get(project)?.section.querySelector(".toc a[href='#" + CSS.escape(activeId) + "']");
    if (nextLink) {
        nextLink.classList.add("active");
        activeLink = nextLink;
        activeSectionId = activeId;
        let parent = nextLink.parentElement;
        while (parent) {
            if (parent.tagName === "DETAILS") {
                parent.open = true;
            }
            parent = parent.parentElement;
        }
    }
}

projectOptions.forEach((summary) => {
    summary.addEventListener("click", (event) => {
        event.preventDefault();
        const section = summary.closest("[data-project-nav]");
        if (section.open && document.body.dataset.project === section.dataset.projectNav) {
            section.open = false;
            return;
        }
        const project = section.dataset.projectNav;
        setProject(project, {
            updateHash: true,
            forceHash: true,
            scrollContent: true,
            scrollSubmenu: true
        });
    });
});

document.addEventListener("click", (event) => {
    const summaryLink = event.target.closest("summary a");
    if (summaryLink) {
        event.stopPropagation();
    }
    const hashLink = event.target.closest("a[href^='#']");
    if (!hashLink) {
        return;
    }
    const targetProject = projectFromSectionId(hashLink.hash.slice(1));
    if (targetProject) {
        setProject(targetProject, {
            scrollSubmenu: targetProject !== document.body.dataset.project
        });
        document.body.classList.remove("sidebar-open");
        sidebarToggle?.setAttribute("aria-expanded", "false");
        window.setTimeout(queueScrollSpy, 0);
    }
});

sidebarToggle?.addEventListener("click", () => {
    const open = !document.body.classList.contains("sidebar-open");
    document.body.classList.toggle("sidebar-open", open);
    sidebarToggle.setAttribute("aria-expanded", String(open));
});

sidebarCollapse?.addEventListener("click", () => {
    const collapsed = !document.body.classList.contains("sidebar-collapsed");
    document.body.classList.toggle("sidebar-collapsed", collapsed);
    sidebarCollapse.setAttribute("aria-expanded", String(!collapsed));
    const label = collapsed ? "Expand sidebar" : "Collapse sidebar";
    sidebarCollapse.setAttribute("aria-label", label);
    sidebarCollapse.setAttribute("title", label);
    if (sidebarCollapseLabel) {
        sidebarCollapseLabel.textContent = label;
    }
});

themeSwitcher?.addEventListener("click", () => switchTheme(true));

window.addEventListener("hashchange", () => {
    setProject(projectFromHash() || document.body.dataset.project, false);
});
window.addEventListener("scroll", queueScrollSpy, { passive: true });
window.addEventListener("resize", queueScrollSpy);

applyTheme(preferredTheme(), false);
setProject(projectFromHash() || projectOptions[0]?.dataset.projectOption, {
    updateHash: true
});
queueScrollSpy();
