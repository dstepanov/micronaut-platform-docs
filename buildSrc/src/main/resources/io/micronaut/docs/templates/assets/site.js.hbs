const searchIndexScriptUrl = "{{{searchIndexScriptUrl}}}";
const sidebarMenuUrl = "{{{sidebarMenuUrl}}}";
const sidebarMenuScriptUrl = "{{{sidebarMenuScriptUrl}}}";
