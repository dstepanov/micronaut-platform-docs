function searchKindLabel(item) {
    if (item.kind === "project") {
        return "Project";
    }
    if (item.kind === "configuration") {
        return "Property";
    }
    if (item.kind === "configuration-reference") {
        return "Configuration reference";
    }
    if (item.kind === "api-type") {
        return "Class";
    }
    if (item.kind === "api") {
        return "API reference";
    }
    if (item.kind === "repository") {
        return "Repository";
    }
    if (item.kind === "content") {
        return "Documentation";
    }
    return "Section";
}

function searchResultDetail(item) {
    if (item.kind === "project") {
        return "Open documentation";
    }
    if (item.kind === "configuration") {
        return item.detail || "Configuration property";
    }
    if (item.kind === "configuration-reference") {
        return item.detail || "Open configuration reference";
    }
    if (item.kind === "api-type") {
        return item.detail ? "Class in " + item.detail : "Open API class";
    }
    if (item.kind === "api") {
        return item.detail || "Open API and Javadoc reference";
    }
    if (item.kind === "repository") {
        return item.detail || "Open GitHub repository";
    }
    if (item.kind === "content") {
        return item.detail || "Documentation match";
    }
    return item.detail || "Documentation section";
}

function searchScopeMatchesItem(item) {
    if (searchScope === "projects") {
        return item.kind === "project";
    }
    if (searchScope === "docs") {
        return item.kind === "section" || item.kind === "content";
    }
    if (searchScope === "config") {
        return item.kind === "configuration" || item.kind === "configuration-reference";
    }
    if (searchScope === "api") {
        return item.kind === "api" || item.kind === "api-type";
    }
    if (searchScope === "repositories") {
        return item.kind === "repository";
    }
    return true;
}

function setSearchOpen(open) {
    if (searchDialog) {
        searchDialog.hidden = !open;
    }
    if (searchBackdrop) {
        searchBackdrop.hidden = !open;
    }
    document.body.classList.toggle("search-open", open);
    if (searchTrigger) {
        searchTrigger.setAttribute("aria-expanded", String(open));
    }
    if (searchRoot) {
        searchRoot.classList.toggle("is-open", open);
    }
    if (searchInput) {
        searchInput.setAttribute("aria-expanded", String(open));
        if (!open) {
            searchInput.removeAttribute("aria-activedescendant");
        }
    }
    updateSearchUiState();
}

function openSearchDialog(selectValue = false) {
    setSearchOpen(true);
    if ((searchInput?.value || "").trim().length >= 2) {
        queueSearch();
    } else {
        renderSearchPrompt();
    }
    window.requestAnimationFrame(() => {
        searchInput?.focus();
        if (selectValue) {
            searchInput?.select();
        }
    });
}

function searchContainsTarget(target) {
    return Boolean((searchRoot && searchRoot.contains(target))
        || (searchDialog && searchDialog.contains(target))
        || (searchBackdrop && searchBackdrop.contains(target)));
}

function setSearchScope(scope) {
    searchScope = scope || "all";
    searchScopeButtons.forEach((button) => {
        const selected = button.dataset.searchScope === searchScope;
        button.classList.toggle("active", selected);
        button.setAttribute("aria-selected", String(selected));
    });
    setSearchOpen(true);
    if ((searchInput?.value || "").trim().length >= 2) {
        queueSearch();
    } else {
        renderSearchPrompt();
    }
    searchInput?.focus();
}

function projectTitleForSearch(project) {
    const escapedProject = CSS.escape(project);
    const article = projectArticles.get(project);
    const referenceButton = article?.querySelector("[data-reference-open][data-reference-project='" + escapedProject + "']");
    const card = document.querySelector("[data-project-card='" + escapedProject + "']");
    return referenceButton?.dataset.referenceProjectName
        || card?.querySelector("h3")?.textContent?.trim()
        || project;
}

function repositoryDisplayPath(url) {
    try {
        const parsed = new URL(url, window.location.href);
        return parsed.hostname.replace(/^www\./, "") + parsed.pathname.replace(/\/$/, "");
    } catch (error) {
        return String(url || "").replace(/^https?:\/\//, "").replace(/\/$/, "");
    }
}

function buildCommandSearchItems() {
    const items = [];
    const references = Array.from(document.querySelectorAll("[data-reference-open][data-reference-url]"));
    references.forEach((button) => {
        const project = button.dataset.referenceProject || "";
        const url = button.dataset.referenceUrl || "";
        if (!project || !url) {
            return;
        }
        const projectTitle = button.dataset.referenceProjectName || projectTitleForSearch(project);
        const referenceKind = button.dataset.referenceKind || "";
        const kind = referenceKind === "api" ? "api" : "configuration-reference";
        const title = referenceKind === "api" ? projectTitle + " API / Javadoc" : projectTitle + " configuration reference";
        const detail = referenceKind === "api" ? "API and Javadoc reference" : "Configuration reference";
        items.push({
            kind,
            project,
            projectTitle,
            title,
            href: "#" + project,
            detail,
            referenceKind,
            referenceUrl: url,
            searchText: projectTitle + " " + project + " " + title + " " + detail + " reference docs javadoc api configuration"
        });
    });
    projectCards.forEach((card) => {
        const project = card.dataset.projectCard || "";
        if (!project) {
            return;
        }
        const projectTitle = card.querySelector("h3")?.textContent?.trim() || projectTitleForSearch(project);
        const repositoryLink = Array.from(card.querySelectorAll("a[href]"))
            .find((link) => /github\.com/i.test(link.href));
        const repositoryUrl = repositoryLink?.getAttribute("href") || "";
        if (!repositoryUrl) {
            return;
        }
        const version = card.querySelector(".project-card-version")?.textContent?.trim() || "";
        const repositoryPath = repositoryDisplayPath(repositoryUrl);
        items.push({
            kind: "repository",
            project,
            projectTitle,
            title: projectTitle,
            href: repositoryUrl,
            detail: version ? repositoryPath + " - " + version : repositoryPath,
            externalUrl: repositoryUrl,
            searchText: projectTitle + " " + project + " github repository source module metadata " + version + " " + repositoryUrl
        });
    });
    return items;
}

function searchItemKey(item) {
    return [
        item.kind || "",
        item.project || "",
        item.title || "",
        item.referenceUrl || item.externalUrl || item.href || ""
    ].join("|");
}

function augmentSearchIndex(index) {
    if (!index || index.__platformAugmented) {
        return index;
    }
    index.items = Array.isArray(index.items) ? index.items : [];
    index.terms = index.terms || {};
    const existing = new Set(index.items.map(searchItemKey));
    buildCommandSearchItems().forEach((item) => {
        const key = searchItemKey(item);
        if (existing.has(key)) {
            return;
        }
        existing.add(key);
        index.items.push(item);
        addSearchIndexTerms(index, index.items.length - 1, item.searchText || item.title || "");
    });
    Object.defineProperty(index, "__platformAugmented", {
        value: true,
        enumerable: false
    });
    return index;
}

function updateSearchUiState() {
    const hasValue = Boolean(searchInput?.value);
    const hasResults = Boolean(searchResults && !searchResults.hidden);
    const open = Boolean(searchDialog && !searchDialog.hidden);
    const active = Boolean(searchRoot && searchRoot.contains(document.activeElement))
        || Boolean(searchDialog && searchDialog.contains(document.activeElement))
        || open;
    if (searchClear) {
        searchClear.hidden = !hasValue;
        searchClear.setAttribute("aria-hidden", String(!hasValue));
        searchClear.tabIndex = hasValue ? 0 : -1;
    }
    if (searchInput) {
        searchInput.setAttribute("aria-expanded", String(open));
    }
    if (searchTrigger) {
        searchTrigger.setAttribute("aria-expanded", String(open));
    }
    if (searchRoot) {
        searchRoot.classList.toggle("has-value", hasValue);
        searchRoot.classList.toggle("has-results", hasResults);
        searchRoot.classList.toggle("is-active", active);
        searchRoot.classList.toggle("is-open", open);
    }
}

function stripSearchSectionNumber(value) {
    return String(value || "")
        .replace(/^\s*\d+(?:\.\d+)*\s+/, "")
        .trim();
}

function searchDisplayTitle(projectTitle, title) {
    const normalizedTitle = stripSearchSectionNumber(title);
    const prefix = String(projectTitle || "").trim();
    if (prefix && normalizedTitle.toLowerCase().startsWith((prefix + " ").toLowerCase())) {
        return normalizedTitle.slice(prefix.length).trim();
    }
    return normalizedTitle;
}

function projectNameAlias(item) {
    const title = String(item.projectTitle || item.title || "");
    return normalizeSearchText(title.replace(/^Micronaut\s+/i, ""));
}

function addSearchIndexTerms(index, itemId, value) {
    const tokens = searchTokens(value);
    const allTerms = new Set();
    for (const token of tokens) {
        const prefixLength = Math.min(token.length, 20);
        allTerms.add(token);
        for (let length = 2; length < prefixLength; length++) {
            allTerms.add(token.slice(0, length));
        }
    }
    for (const term of allTerms) {
        if (!index.terms[term]) {
            index.terms[term] = [];
        }
        index.terms[term].push(itemId);
    }
}

function buildSidebarSearchIndex() {
    const index = { items: [], terms: {} };
    for (const [project, data] of projectSections.entries()) {
        const projectTitle = data.summary.querySelector(".project-title")?.textContent?.trim() || project;
        const projectItem = {
            kind: "project",
            project,
            projectTitle,
            title: projectTitle,
            href: "#" + project,
            detail: "Open documentation"
        };
        index.items.push(projectItem);
        addSearchIndexTerms(index, index.items.length - 1, project + " " + projectTitle);

        const links = Array.from(data.section.querySelectorAll(".toc a[href^='#']"));
        for (const link of links) {
            const title = link.querySelector(".toc-title")?.textContent?.trim()
                || stripSearchSectionNumber(link.textContent.replace(/\s+/g, " "));
            const sectionItem = {
                kind: "section",
                project,
                projectTitle,
                title,
                href: link.getAttribute("href"),
                detail: projectTitle
            };
            index.items.push(sectionItem);
            addSearchIndexTerms(index, index.items.length - 1, project + " " + projectTitle + " " + title);
        }
    }
    return index;
}

function loadSearchIndex() {
    if (!searchIndexPromise) {
        if (window.__PLATFORM_SEARCH_INDEX__) {
            searchIndexPromise = Promise.resolve(window.__PLATFORM_SEARCH_INDEX__);
        } else if (window.location.protocol === "file:") {
            searchIndexPromise = loadSearchIndexScript().catch(() => buildSidebarSearchIndex());
        } else {
            searchIndexPromise = fetch(searchIndexUrl, { cache: "no-cache" })
                .then((response) => {
                    if (!response.ok) {
                        throw new Error("Unable to load search index");
                    }
                    return response.json();
                })
                .catch(() => buildSidebarSearchIndex());
        }
    }
    return searchIndexPromise.then(augmentSearchIndex);
}

function loadSearchIndexScript() {
    return new Promise((resolve, reject) => {
        const script = document.createElement("script");
        script.src = searchIndexScriptUrl;
        script.async = true;
        script.onload = () => {
            if (window.__PLATFORM_SEARCH_INDEX__) {
                resolve(window.__PLATFORM_SEARCH_INDEX__);
            } else {
                reject(new Error("Search index script did not define an index"));
            }
        };
        script.onerror = () => reject(new Error("Unable to load search index script"));
        document.head.appendChild(script);
    });
}

function loadSidebarMenuScript() {
    return new Promise((resolve, reject) => {
        if (window.__PLATFORM_SIDEBAR_MENU__) {
            resolve(window.__PLATFORM_SIDEBAR_MENU__);
            return;
        }
        const script = document.createElement("script");
        script.src = sidebarMenuScriptUrl;
        script.async = true;
        script.onload = () => {
            if (window.__PLATFORM_SIDEBAR_MENU__) {
                resolve(window.__PLATFORM_SIDEBAR_MENU__);
            } else {
                reject(new Error("Sidebar menu script did not define a menu"));
            }
        };
        script.onerror = () => reject(new Error("Unable to load sidebar menu script"));
        document.head.appendChild(script);
    });
}

function requestSidebarMenu() {
    if (window.__PLATFORM_SIDEBAR_MENU__) {
        return Promise.resolve(window.__PLATFORM_SIDEBAR_MENU__);
    }
    if (window.location.protocol === "file:") {
        return loadSidebarMenuScript();
    }
    return fetch(sidebarMenuUrl, { cache: "no-cache" })
        .then((response) => {
            if (!response.ok) {
                throw new Error("Unable to load sidebar menu");
            }
            return response.text();
        })
        .catch(() => loadSidebarMenuScript());
}

function refreshProjectSections() {
    projectOptions = Array.from(document.querySelectorAll("[data-project-option]"));
    projectSections = new Map(projectOptions.map((summary) => {
        const section = summary.closest("[data-project-nav]");
        return [section.dataset.projectNav, { section, summary, article: projectArticles.get(section.dataset.projectNav) }];
    }));
    headingCache.clear();
    renderPageIndex(document.body.dataset.project);
}

function showSidebarMenuError() {
    if (!sidebarMenu) {
        return;
    }
    sidebarMenu.innerHTML = "<div class=\"sidebar-menu-error\">Projects could not be loaded.</div>";
    sidebarMenu.setAttribute("aria-busy", "false");
}

function loadSidebarMenu() {
    if (!sidebarMenu || sidebarMenu.dataset.menuLoaded === "true") {
        return Promise.resolve();
    }
    sidebarMenu.setAttribute("aria-busy", "true");
    return requestSidebarMenu()
        .then((html) => {
            sidebarMenu.innerHTML = html;
            sidebarMenu.dataset.menuLoaded = "true";
            sidebarMenu.setAttribute("aria-busy", "false");
            bindProjectOptions();
        })
        .catch((errorValue) => {
            showSidebarMenuError();
            throw errorValue;
        });
}

function platformDocumentCache() {
    window.__PLATFORM_DOCUMENTS__ = window.__PLATFORM_DOCUMENTS__ || {};
    return window.__PLATFORM_DOCUMENTS__;
}

function cacheBustedUrl(url) {
    if (!url || window.location.protocol === "file:") {
        return url;
    }
    const separator = url.includes("?") ? "&" : "?";
    return url + separator + "v=" + Date.now();
}

function loadProjectDocumentScript(project, scriptUrl, options) {
    const settings = options || {};
    const documents = platformDocumentCache();
    if (Object.prototype.hasOwnProperty.call(documents, project)) {
        return Promise.resolve(documents[project]);
    }
    if (!scriptUrl) {
        return Promise.reject(new Error("Project document script URL is not configured"));
    }
    return new Promise((resolve, reject) => {
        const script = document.createElement("script");
        script.src = settings.bustCache ? cacheBustedUrl(scriptUrl) : scriptUrl;
        script.async = true;
        script.onload = () => {
            const cachedDocuments = platformDocumentCache();
            if (Object.prototype.hasOwnProperty.call(cachedDocuments, project)) {
                resolve(cachedDocuments[project]);
            } else {
                reject(new Error("Project document script did not define " + project));
            }
        };
        script.onerror = () => reject(new Error("Unable to load project document script"));
        document.head.appendChild(script);
    });
}

function requestProjectDocument(project, article) {
    const documentUrl = article.dataset.documentUrl;
    const documentScriptUrl = article.dataset.documentScriptUrl;
    if (window.location.protocol === "file:") {
        return loadProjectDocumentScript(project, documentScriptUrl);
    }
    if (!documentUrl) {
        return loadProjectDocumentScript(project, documentScriptUrl);
    }
    return fetch(documentUrl, { cache: "no-cache" })
        .then((response) => {
            if (!response.ok) {
                throw new Error("Unable to load project document");
            }
            return response.text();
        })
        .catch(() => loadProjectDocumentScript(project, documentScriptUrl, { bustCache: true }));
}

function hydrateGuideDocument(article) {
    try {
        upgradeCodeBlocks(article);
        ensureMultiLanguageSelectors(article);
        integrateMultiLanguageTabs(article);
        if (typeof postProcessCodeCallouts === "function") {
            postProcessCodeCallouts();
        }
    } catch (errorValue) {
        console.warn("Documentation loaded, but post-processing failed.", errorValue);
    }
}

function showProjectDocumentError(article) {
    const loading = article.querySelector("[data-document-loading]");
    const error = article.querySelector("[data-document-error]");
    const content = article.querySelector("[data-document-content]");
    if (content && (content.childElementCount > 0 || content.textContent.trim())) {
        if (loading) {
            loading.hidden = true;
        }
        if (error) {
            error.hidden = true;
        }
        article.dataset.documentLoaded = "true";
        article.setAttribute("aria-busy", "false");
        return;
    }
    if (loading) {
        loading.hidden = true;
    }
    if (error) {
        error.hidden = false;
    }
    article.setAttribute("aria-busy", "false");
}

function loadProjectDocument(project) {
    const article = projectArticles.get(project);
    if (!article || article.dataset.documentLoaded === "true") {
        return Promise.resolve(article);
    }
    if (projectDocumentPromises.has(project)) {
        return projectDocumentPromises.get(project);
    }

    const loading = article.querySelector("[data-document-loading]");
    const error = article.querySelector("[data-document-error]");
    if (loading) {
        loading.hidden = false;
    }
    if (error) {
        error.hidden = true;
    }
    article.setAttribute("aria-busy", "true");

    const promise = requestProjectDocument(project, article)
        .then((html) => {
            const content = article.querySelector("[data-document-content]");
            if (content) {
                content.innerHTML = html;
            }
            if (loading) {
                loading.hidden = true;
            }
            article.dataset.documentLoaded = "true";
            article.setAttribute("aria-busy", "false");
            headingCache.delete(project);
            hydrateGuideDocument(article);
            return article;
        })
        .catch((errorValue) => {
            projectDocumentPromises.delete(project);
            showProjectDocumentError(article);
            throw errorValue;
        });
    projectDocumentPromises.set(project, promise);
    return promise;
}

function prefetchProjectDocument(project) {
    loadProjectDocument(project).catch(() => {
        // The visible project load path will show the error state if the user opens it.
    });
}

function renderSearchPrompt() {
    if (!searchResults) {
        return;
    }
    const typeBadges = searchScope === "all"
        ? `
            <div class="site-search-prompt-badges" aria-label="Additional result types in All">
                <span class="site-search-prompt-badge">Class</span>
                <span class="site-search-prompt-badge">Property</span>
            </div>
        `
        : "";
    searchResults.hidden = false;
    searchResults.innerHTML = `
        <div class="site-search-prompt">
            <div class="site-search-prompt-title">
                <strong>Search the platform docs</strong>
                <span>Find projects, guide sections, API classes, configuration properties, and GitHub repositories from the same command surface.</span>
            </div>
            ${typeBadges}
        </div>
    `;
    searchActiveIndex = -1;
    searchInput?.removeAttribute("aria-activedescendant");
    updateSearchUiState();
}

function clearSearchResults() {
    if (searchResults) {
        searchResults.hidden = true;
        searchResults.innerHTML = "";
    }
    searchActiveIndex = -1;
    searchInput?.removeAttribute("aria-activedescendant");
    updateSearchUiState();
}

function closeSearchResults() {
    clearSearchResults();
    setSearchOpen(false);
}

function setSearchActive(index) {
    const links = Array.from(searchResults?.querySelectorAll("[data-search-result]") || []);
    if (!links.length) {
        searchActiveIndex = -1;
        searchInput?.removeAttribute("aria-activedescendant");
        return;
    }
    searchActiveIndex = Math.max(0, Math.min(index, links.length - 1));
    links.forEach((link, linkIndex) => {
        link.classList.toggle("active", linkIndex === searchActiveIndex);
        link.setAttribute("aria-selected", String(linkIndex === searchActiveIndex));
    });
    const activeResult = links[searchActiveIndex];
    if (activeResult?.id) {
        searchInput?.setAttribute("aria-activedescendant", activeResult.id);
    }
    activeResult?.scrollIntoView({ block: "nearest" });
}

function scoreSearchResult(item, tokens, queryText, matchedTokenCount) {
    const title = normalizeSearchText(item.title);
    const project = normalizeSearchText(item.projectTitle);
    const projectAlias = projectNameAlias(item);
    const projectSlug = normalizeSearchText(item.project);
    const detail = normalizeSearchText(item.detail);
    let score = matchedTokenCount * 100;
    if (title === queryText) {
        score += 90;
    } else if (title.startsWith(queryText)) {
        score += 70;
    } else if (title.includes(queryText)) {
        score += 45;
    }
    if (project === queryText) {
        score += 60;
    } else if (project.startsWith(queryText)) {
        score += 35;
    } else if (project.includes(queryText)) {
        score += 20;
    }
    if (projectAlias && projectAlias === queryText) {
        score += item.kind === "project" ? 160 : 90;
    } else if (projectAlias && projectAlias.startsWith(queryText)) {
        score += item.kind === "project" ? 96 : 52;
    } else if (projectAlias && projectAlias.includes(queryText)) {
        score += item.kind === "project" ? 44 : 20;
    }
    if (projectSlug && projectSlug === queryText && item.kind === "project") {
        score += 120;
    }
    if (detail.includes(queryText)) {
        score += 8;
    }
    if (item.kind === "project") {
        score += 72;
    } else if (item.kind === "configuration") {
        score += 24;
    } else if (item.kind === "api-type") {
        score += 36;
    } else if (item.kind === "configuration-reference" || item.kind === "api") {
        score += 28;
    } else if (item.kind === "repository") {
        score += 18;
    }
    for (const token of tokens) {
        if (title.startsWith(token)) {
            score += 10;
        }
        if (projectAlias && projectAlias === token && item.kind === "project") {
            score += 28;
        }
    }
    return score;
}

function apiTypeSearchText(item) {
    if (!item.__apiSearchText) {
        const source = [item.title, item.detail].join(" ");
        const compact = source.toLowerCase().replace(/[^a-z0-9]+/g, "");
        Object.defineProperty(item, "__apiSearchText", {
            value: normalizeSearchText(source) + " " + compact,
            enumerable: false
        });
    }
    return item.__apiSearchText;
}

function searchApiTypeResults(index, tokens, queryText) {
    if (searchScope !== "all" && searchScope !== "api") {
        return [];
    }
    return index.items
        .map((item) => {
            if (item.kind !== "api-type") {
                return undefined;
            }
            const searchText = apiTypeSearchText(item);
            const matchedTokenCount = tokens.filter((token) => searchText.includes(token)).length;
            if (matchedTokenCount !== tokens.length) {
                return undefined;
            }
            return {
                item,
                score: scoreSearchResult(item, tokens, queryText, matchedTokenCount)
            };
        })
        .filter(Boolean);
}

function findSearchResults(index, query) {
    const tokens = searchTokens(query);
    if (!tokens.length) {
        return [];
    }
    const counts = new Map();
    for (const token of tokens) {
        const ids = index.terms[token] || [];
        for (const id of ids) {
            counts.set(id, (counts.get(id) || 0) + 1);
        }
    }
    const requiredMatches = tokens.length;
    let matches = Array.from(counts.entries()).filter((entry) => entry[1] === requiredMatches);
    if (!matches.length && query.trim().length >= 3) {
        matches = Array.from(counts.entries()).filter((entry) => entry[1] > 0);
    }
    const queryText = normalizeSearchText(query);
    return matches
        .map(([id, matchedTokenCount]) => {
            const item = index.items[id];
            return {
                item,
                score: scoreSearchResult(item, tokens, queryText, matchedTokenCount)
            };
        })
        .concat(searchApiTypeResults(index, tokens, queryText))
        .sort((left, right) => right.score - left.score || left.item.title.localeCompare(right.item.title))
        .map((result) => result.item)
        .filter(searchScopeMatchesItem)
        .slice(0, 16);
}

function renderSearchResults(results, query) {
    if (!searchResults) {
        return;
    }
    if (!query.trim() || query.trim().length < 2) {
        clearSearchResults();
        return;
    }
    setSearchOpen(true);
    searchResults.hidden = false;
    searchActiveIndex = -1;
    searchInput?.removeAttribute("aria-activedescendant");
    if (!results.length) {
        searchResults.innerHTML = `<div class="site-search-empty">No results for <strong>${escapeHtml(query.trim())}</strong></div>`;
        updateSearchUiState();
        return;
    }
    searchResults.innerHTML = results.map((item, resultIndex) => {
        const isProject = item.kind === "project";
        const isConfiguration = item.kind === "configuration";
        const isExternal = Boolean(item.externalUrl);
        const projectAttribute = isProject ? " data-search-project-link" : "";
        const referenceKind = item.kind === "api-type" ? "api" : (item.referenceKind || item.kind || "configuration");
        const referenceTitle = item.kind === "api-type" ? item.title : "";
        const referenceAttribute = item.referenceUrl
            ? ` data-search-reference-url="${escapeHtml(item.referenceUrl)}" data-search-reference-kind="${escapeHtml(referenceKind)}" data-search-reference-title="${escapeHtml(referenceTitle)}" data-search-project="${escapeHtml(item.project)}"`
            : "";
        const externalAttribute = isExternal
            ? ` data-search-external-url="${escapeHtml(item.externalUrl)}" target="_blank" rel="noopener"`
            : "";
        const resultLabel = searchKindLabel(item);
        const resultDetail = searchResultDetail(item);
        const resultTitle = isProject || isConfiguration || item.kind === "api-type" ? item.title : searchDisplayTitle(item.projectTitle, item.title);
        const projectLabel = isProject ? "" : (item.kind === "repository" ? "GitHub repository" : item.projectTitle);
        const resultKindBadge = searchScope === "all" && (item.kind === "api-type" || item.kind === "configuration")
            ? `<span class="site-search-result-kind">${escapeHtml(resultLabel)}</span>`
            : "";
        const resultMeta = resultKindBadge || projectLabel
            ? `
                    <span class="site-search-result-meta">
                        ${resultKindBadge}
                        ${projectLabel ? `<span class="site-search-result-project">${escapeHtml(projectLabel)}</span>` : ""}
                    </span>`
            : "";
        return `
            <a id="site-search-result-${resultIndex}" class="site-search-result" href="${escapeHtml(item.href)}" data-search-result data-search-kind="${escapeHtml(item.kind || "")}"${projectAttribute}${referenceAttribute}${externalAttribute} role="option" aria-selected="false">
                ${searchCommandIcon(item.kind)}
                <span class="site-search-result-body">
                    ${resultMeta}
                    <strong>${escapeHtml(resultTitle)}</strong>
                    <small>${escapeHtml(resultDetail)}</small>
                </span>
            </a>
        `;
    }).join("");
    updateSearchUiState();
}

function runSearch() {
    const query = searchInput?.value || "";
    setSearchOpen(true);
    updateSearchUiState();
    if (query.trim().length < 2) {
        renderSearchPrompt();
        return;
    }
    if (searchResults) {
        searchResults.hidden = false;
        searchResults.innerHTML = "<div class=\"site-search-empty\">Loading...</div>";
        updateSearchUiState();
    }
    loadSearchIndex()
        .then((index) => {
            if ((searchInput?.value || "") !== query) {
                return;
            }
            renderSearchResults(findSearchResults(index, query), query);
        })
        .catch(() => {
            if (searchResults) {
                searchResults.hidden = false;
                searchResults.innerHTML = "<div class=\"site-search-empty\">Search index unavailable</div>";
                updateSearchUiState();
            }
        });
}

function queueSearch() {
    if (searchFrame) {
        window.cancelAnimationFrame(searchFrame);
    }
    searchFrame = window.requestAnimationFrame(() => {
        searchFrame = 0;
        runSearch();
    });
}

function preferredTheme() {
    if (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches) {
        return "dark";
    }
    return "light";
}

function applyTheme(theme) {
    const dark = theme === "dark";
    document.body.classList.toggle("dark-mode", dark);
    if (themeSwitcher) {
        const label = dark ? "Switch to light theme" : "Switch to dark theme";
        themeSwitcher.setAttribute("aria-label", label);
        themeSwitcher.setAttribute("aria-pressed", String(dark));
        themeSwitcher.setAttribute("title", label);
    }
}

function switchTheme() {
    themeManuallySelected = true;
    applyTheme(document.body.classList.contains("dark-mode") ? "light" : "dark");
}

window.switchTheme = switchTheme;

function projectFromHash() {
    const hash = decodeURIComponent(window.location.hash.slice(1));
    if (!hash || hash === overviewHash) {
        return undefined;
    }
    return projectFromSectionId(hash);
}

function projectFromSectionId(sectionId) {
    if (firstSections[sectionId]) {
        return sectionId;
    }
    return projectSlugsByLength.find((project) => sectionId.startsWith(project + "-"));
}

function isProjectRootSection(sectionId, project) {
    return Boolean(sectionId && project && sectionId === project && firstSections[project]);
}

function projectPageIndexItems(project) {
    return pageIndexItems[project] || [];
}

function projectPageIndexItem(project, sectionId) {
    return projectPageIndexItems(project).find((item) => item.id === sectionId);
}

function sectionHeadings(project) {
    if (!headingCache.has(project)) {
        const article = projectSections.get(project)?.article || projectArticles.get(project);
        const headings = projectPageIndexItems(project)
            .map((item) => article?.querySelector("#" + CSS.escape(item.id)))
            .filter(Boolean);
        headingCache.set(project, headings);
    }
    return headingCache.get(project);
}

function pageIndexRoot(project, activeId) {
    const items = projectPageIndexItems(project);
    if (!items.length) {
        return undefined;
    }
    const activeItem = projectPageIndexItem(project, activeId) || items[0];
    const rootNumber = activeItem.number.split(".")[0];
    return items.find((item) => item.level === 0 && item.number === rootNumber) || activeItem;
}

function pageIndexHeadingItems(project, activeId) {
    const root = pageIndexRoot(project, activeId);
    if (!root) {
        return [];
    }
    const items = projectPageIndexItems(project);
    const childItems = items
        .filter((item) => item.level > 0 && item.number.startsWith(root.number + "."));
    const visibleItems = childItems.length
        ? childItems
        : items.filter((item) => item.level === 0);
    return visibleItems.map((item) => ({
        id: item.id,
        level: Math.min(Math.max(item.level, 1), 3),
        label: item.label
    }));
}

function clearPageIndexActiveLink() {
    if (activePageIndexLink) {
        activePageIndexLink.classList.remove("active");
        activePageIndexLink.removeAttribute("aria-current");
        activePageIndexLink = undefined;
    }
}

function hidePageIndex() {
    clearPageIndexActiveLink();
    document.body.classList.remove("page-index-active");
    if (pageIndex) {
        pageIndex.hidden = true;
    }
    if (pageIndexNav) {
        pageIndexNav.innerHTML = "";
    }
    activePageIndexRootId = "";
}

function renderPageIndex(project, activeId) {
    if (!pageIndex || !pageIndexNav || !project || document.body.classList.contains("overview-active")) {
        hidePageIndex();
        return;
    }
    const article = projectSections.get(project)?.article || projectArticles.get(project);
    if (!article || article.dataset.documentLoaded !== "true") {
        hidePageIndex();
        return;
    }
    const resolvedActiveId = activeId || activeSectionId || activeSectionFromScroll();
    const root = pageIndexRoot(project, resolvedActiveId);
    const items = pageIndexHeadingItems(project, resolvedActiveId);
    if (!items.length) {
        hidePageIndex();
        return;
    }
    pageIndexNav.innerHTML = items.map((item) => `
        <a class="page-index-link page-index-link-level-${item.level}" href="#${escapeHtml(item.id)}" data-page-index-link data-section="${escapeHtml(item.id)}">
            ${escapeHtml(item.label)}
        </a>
    `).join("");
    if (pageIndexTop) {
        const target = root?.id || project;
        const label = root?.label || projectTitleForSearch(project);
        pageIndexTop.href = "#" + target;
        pageIndexTop.setAttribute("aria-label", "Back to " + label);
        pageIndexTop.setAttribute("title", "Back to " + label);
    }
    activePageIndexRootId = root?.id || "";
    pageIndex.hidden = false;
    document.body.classList.add("page-index-active");
    refreshPageIndex(resolvedActiveId);
}

function refreshPageIndex(activeId) {
    if (!pageIndex || !pageIndexNav) {
        clearPageIndexActiveLink();
        return;
    }
    const project = document.body.dataset.project;
    if (pageIndex.hidden) {
        if (activeId && project) {
            renderPageIndex(project, activeId);
        }
        return;
    }
    const root = pageIndexRoot(project, activeId);
    if (root?.id && root.id !== activePageIndexRootId) {
        renderPageIndex(project, activeId);
        return;
    }
    const nextLink = activeId
        ? pageIndexNav.querySelector("[data-page-index-link][data-section='" + CSS.escape(activeId) + "']")
        : undefined;
    if (activePageIndexLink && activePageIndexLink !== nextLink) {
        activePageIndexLink.classList.remove("active");
        activePageIndexLink.removeAttribute("aria-current");
        activePageIndexLink = undefined;
    }
    if (nextLink) {
        nextLink.classList.add("active");
        nextLink.setAttribute("aria-current", "location");
        activePageIndexLink = nextLink;
    }
}

function sidebarSectionIdForActive(project, activeId) {
    const section = projectSections.get(project)?.section;
    if (!section || !activeId) {
        return activeId;
    }
    if (section.querySelector(".toc a[href='#" + CSS.escape(activeId) + "']")) {
        return activeId;
    }
    return pageIndexRoot(project, activeId)?.id || activeId;
}

function activeSectionFromScroll() {
    const project = document.body.dataset.project;
    if (!firstSections[project]) {
        return "";
    }
    const headings = sectionHeadings(project);
    const topbarHeight = document.querySelector(".topbar")?.getBoundingClientRect().height ?? 0;
    const activationTop = topbarHeight + 24;
    let activeId = firstSections[project];
    for (const heading of headings) {
        if (heading.getBoundingClientRect().top <= activationTop) {
            activeId = heading.id;
        } else {
            break;
        }
    }
    return activeId;
}

function queueScrollSpy() {
    if (scrollSpyFrame) {
        return;
    }
    scrollSpyFrame = window.requestAnimationFrame(() => {
        scrollSpyFrame = 0;
        const nextActiveSectionId = activeSectionFromScroll();
        if (nextActiveSectionId && nextActiveSectionId !== activeSectionId) {
            refreshActiveLink(nextActiveSectionId);
        }
    });
}

function focusSearchTarget(target) {
    if (focusedSearchTarget && focusedSearchTarget !== target) {
        focusedSearchTarget.classList.remove("platform-search-target");
    }
    focusedSearchTarget = target;
    if (!target) {
        return;
    }
    target.classList.add("platform-search-target");
    if (!target.hasAttribute("tabindex")) {
        target.setAttribute("tabindex", "-1");
    }
    target.focus({ preventScroll: true });
}

function scrollToElementNow(target, options) {
    if (!target) {
        return;
    }
    const settings = options || {};
    if (settings.block === "center") {
        target.scrollIntoView({
            block: "center",
            inline: "nearest",
            behavior: "auto"
        });
        if (settings.focus) {
            focusSearchTarget(target);
        }
        return;
    }
    target.scrollIntoView({
        block: "start",
        inline: "nearest",
        behavior: "auto"
    });
    const topbarHeight = document.querySelector(".topbar")?.getBoundingClientRect().height ?? 0;
    const preferredTop = topbarHeight + 16;
    const targetTop = target.getBoundingClientRect().top;
    if (Math.abs(targetTop - preferredTop) <= 1) {
        return;
    }
    window.scrollBy({
        top: targetTop - preferredTop,
        behavior: "auto"
    });
}

function scrollToSectionNow(sectionId, options) {
    scrollToElementNow(document.getElementById(sectionId), options);
}

function scrollToProjectTitleNow(project, options) {
    const article = projectSections.get(project)?.article || projectArticles.get(project);
    scrollToElementNow(article, options);
}

function scrollToSection(sectionId, options) {
    if (contentScrollFrame) {
        window.cancelAnimationFrame(contentScrollFrame);
    }
    contentScrollFrame = window.requestAnimationFrame(() => {
        contentScrollFrame = window.requestAnimationFrame(() => {
            contentScrollFrame = 0;
            scrollToSectionNow(sectionId, options);
            refreshActiveLink(sectionId);
            queueScrollSpy();
        });
    });
}

function openProjectCard(card) {
    const targetSection = card?.dataset.projectCardTarget || firstSections[card?.dataset.projectCard];
    const targetProject = projectFromSectionId(targetSection) || card?.dataset.projectCard;
    if (!targetProject) {
        return;
    }
    setProject(targetProject, {
        sectionId: targetSection,
        updateHash: true,
        forceHash: true,
        scrollContent: true,
        scrollProjectTitle: true
    });
    closeSidebar();
}

function isInteractiveCardTarget(target, card) {
    if (!(target instanceof Element)) {
        return false;
    }
    const interactive = target.closest("a, button, input, select, textarea, summary, details, iframe, [role='button']");
    return Boolean(interactive && interactive !== card);
}

function scrollToProjectTitle(project, activeSectionIdForProject, options) {
    if (contentScrollFrame) {
        window.cancelAnimationFrame(contentScrollFrame);
    }
    contentScrollFrame = window.requestAnimationFrame(() => {
        contentScrollFrame = window.requestAnimationFrame(() => {
            contentScrollFrame = 0;
            scrollToProjectTitleNow(project, options);
            refreshActiveLink(activeSectionIdForProject);
            queueScrollSpy();
        });
    });
}

function setReferenceExpanded(expanded) {
    document.body.classList.toggle("reference-expanded", expanded);
    if (referenceExpand) {
        const label = expanded ? "Restore reference panel size" : "Expand reference panel";
        referenceExpand.setAttribute("aria-pressed", String(expanded));
        referenceExpand.setAttribute("aria-label", label);
        referenceExpand.setAttribute("title", label);
    }
}

function referenceSwitchLabel(kind, title) {
    if (kind === "api") {
        return "API / Javadoc";
    }
    if (kind === "configuration") {
        return "Configuration";
    }
    return title || "Reference";
}

function renderReferenceSwitcher(project, activeKind) {
    if (!referenceSwitcher) {
        return;
    }
    const article = projectSections.get(project)?.article || projectArticles.get(project);
    const buttons = Array.from(article?.querySelectorAll("[data-reference-open][data-reference-url]") || []);
    if (buttons.length < 2) {
        referenceSwitcher.hidden = true;
        referenceSwitcher.innerHTML = "";
        return;
    }
    referenceSwitcher.hidden = false;
    referenceSwitcher.innerHTML = buttons.map((button) => {
        const kind = button.dataset.referenceKind || "";
        const selected = kind === activeKind;
        return `
            <button class="reference-switch" type="button" role="tab" aria-selected="${selected}" data-reference-switch-kind="${escapeHtml(kind)}">
                ${escapeHtml(referenceSwitchLabel(kind, button.dataset.referenceTitle))}
            </button>
        `;
    }).join("");
}

function openReference(button, options) {
    if (!referencePanel || !referenceFrame || !button) {
        return;
    }
    const settings = options || {};
    const url = settings.url || button.dataset.referenceUrl;
    if (!url) {
        return;
    }
    const wasHidden = referencePanel.hidden;
    if (activeReferenceButton && activeReferenceButton !== button) {
        activeReferenceButton.setAttribute("aria-pressed", "false");
    }
    activeReferenceButton = button;
    activeReferenceKind = button.dataset.referenceKind || "";
    activeReferenceProject = button.dataset.referenceProject || settings.project || activeReferenceProject;
    button.setAttribute("aria-pressed", "true");
    document.body.classList.add("reference-open");
    referencePanel.hidden = false;
    if (referenceOverlay) {
        referenceOverlay.hidden = false;
    }
    const title = settings.title || button.dataset.referenceTitle || "Reference";
    const projectName = settings.projectName || button.dataset.referenceProjectName || "";
    if (referenceTitle) {
        referenceTitle.textContent = title;
    }
    if (referenceProject) {
        referenceProject.textContent = projectName;
    }
    if (referenceOpenNew) {
        referenceOpenNew.href = url;
    }
    if (referenceFrame.getAttribute("src") !== url) {
        referenceFrame.src = url;
    }
    referenceFrame.title = projectName ? projectName + " " + title : title;
    renderReferenceSwitcher(activeReferenceProject, activeReferenceKind);
    if (wasHidden) {
        referencePanel.focus({ preventScroll: true });
    }
    focusReferenceTarget(url);
}

function referenceTargetId(url) {
    const hashIndex = String(url || "").indexOf("#");
    if (hashIndex < 0) {
        return "";
    }
    return decodeURIComponent(String(url).slice(hashIndex + 1));
}

function installReferenceTargetStyles(document) {
    if (!document?.head || document.getElementById("platform-reference-target-style")) {
        return;
    }
    const style = document.createElement("style");
    style.id = "platform-reference-target-style";
    style.textContent = `
        .platform-reference-target > td {
            background: rgba(0, 166, 118, 0.14) !important;
            box-shadow: inset 3px 0 0 #00a676;
        }
        .platform-reference-target:focus {
            outline: 2px solid rgba(0, 166, 118, 0.42);
            outline-offset: 2px;
        }
    `;
    document.head.appendChild(style);
}

function focusReferenceTarget(url) {
    const targetId = referenceTargetId(url);
    if (!targetId || !referenceFrame) {
        return;
    }
    const applyFocus = () => {
        try {
            const document = referenceFrame.contentDocument;
            const target = document?.getElementById(targetId);
            if (!target) {
                return false;
            }
            installReferenceTargetStyles(document);
            document.querySelectorAll(".platform-reference-target").forEach((element) => {
                element.classList.remove("platform-reference-target");
            });
            target.classList.add("platform-reference-target");
            if (!target.hasAttribute("tabindex")) {
                target.setAttribute("tabindex", "-1");
            }
            target.scrollIntoView({
                block: "center",
                inline: "nearest",
                behavior: "auto"
            });
            target.focus({ preventScroll: true });
            return true;
        } catch (ignored) {
            return false;
        }
    };
    if (applyFocus()) {
        return;
    }
    referenceFrame.addEventListener("load", () => {
        window.requestAnimationFrame(applyFocus);
    }, { once: true });
}

function closeReference() {
    if (activeReferenceButton) {
        activeReferenceButton.setAttribute("aria-pressed", "false");
    }
    activeReferenceButton = undefined;
    activeReferenceKind = "";
    activeReferenceProject = "";
    document.body.classList.remove("reference-open");
    setReferenceExpanded(false);
    if (referencePanel) {
        referencePanel.hidden = true;
    }
    if (referenceOverlay) {
        referenceOverlay.hidden = true;
    }
    if (referenceFrame) {
        referenceFrame.removeAttribute("src");
    }
    if (referenceOpenNew) {
        referenceOpenNew.removeAttribute("href");
    }
    if (referenceSwitcher) {
        referenceSwitcher.hidden = true;
        referenceSwitcher.innerHTML = "";
    }
}

function updateReferenceProject(project) {
    if (!activeReferenceKind || !referencePanel || referencePanel.hidden) {
        return;
    }
    const article = projectSections.get(project)?.article || projectArticles.get(project);
    const button = article?.querySelector("[data-reference-open][data-reference-kind='" + CSS.escape(activeReferenceKind) + "']");
    if (button) {
        openReference(button);
    } else {
        closeReference();
    }
}

function closeSidebar() {
    document.body.classList.remove("sidebar-open");
    sidebarToggle?.setAttribute("aria-expanded", "false");
}

function updateTopbarProject(project) {
    const title = project ? projectTitleForSearch(project) : "";
    if (topbarProject) {
        topbarProject.textContent = title;
        topbarProject.hidden = !title;
    }
    if (topbarProjectSeparator) {
        topbarProjectSeparator.hidden = !title;
    }
}

function clickIsOutsideOpenSidebar(event) {
    return document.body.classList.contains("sidebar-open")
        && window.matchMedia("(max-width: 1100px)").matches
        && !event.target.closest(".sidebar")
        && !event.target.closest(".sidebar-toggle");
}

function clearActiveLink() {
    if (activeLink) {
        activeLink.classList.remove("active");
        activeLink = undefined;
    }
    activeSectionId = "";
    refreshPageIndex("");
}

function setOverview(options) {
    const settings = options || {};
    const previousProject = document.body.dataset.project;
    const previous = projectSections.get(previousProject);
    const previousArticle = previous?.article || projectArticles.get(previousProject);
    if (previousArticle) {
        previousArticle.hidden = true;
    }
    if (previous) {
        previous.section.classList.remove("active");
        previous.summary.setAttribute("aria-current", "false");
    }
    document.body.dataset.project = "";
    updateTopbarProject("");
    document.body.classList.add("overview-active");
    if (overviewPage) {
        overviewPage.hidden = false;
    }
    clearActiveLink();
    hidePageIndex();
    closeReference();
    if (settings.updateHash && (settings.forceHash || window.location.hash.slice(1) !== overviewHash)) {
        history.replaceState(null, "", "#" + overviewHash);
    }
    if (settings.scrollContent) {
        window.scrollTo({
            top: 0,
            behavior: "auto"
        });
    }
}

function setProject(project, options) {
    const settings = options || {};
    if (!firstSections[project]) {
        project = projectSlugs[0];
    }
    if (!project) {
        setOverview(settings);
        return;
    }
    const previousProject = document.body.dataset.project;
    const previous = projectSections.get(previousProject);
    const next = projectSections.get(project);
    const previousArticle = previous?.article || projectArticles.get(previousProject);
    const nextArticle = next?.article || projectArticles.get(project);
    document.body.dataset.project = project;
    updateTopbarProject(project);
    document.body.classList.remove("overview-active");
    if (overviewPage) {
        overviewPage.hidden = true;
    }

    if (previousProject !== project) {
        if (previousArticle) {
            previousArticle.hidden = true;
        }
        if (previous) {
            previous.section.classList.remove("active");
            previous.section.open = false;
            previous.summary.setAttribute("aria-current", "false");
        }
    }
    if (nextArticle) {
        nextArticle.hidden = false;
    }
    if (next) {
        next.section.classList.add("active");
        next.section.open = true;
        next.summary.setAttribute("aria-current", "true");
    }

    const firstSection = firstSections[project];
    const targetSection = settings.sectionId || firstSection;
    const projectRootTarget = isProjectRootSection(targetSection, project);
    const activeTargetSection = projectRootTarget ? firstSection : targetSection;
    if (settings.updateHash && (settings.forceHash || !projectFromHash())) {
        history.replaceState(null, "", "#" + targetSection);
    }
    renderPageIndex(project, activeTargetSection);
    refreshActiveLink(settings.scrollContent ? activeTargetSection : undefined);
    if (project !== previousProject) {
        updateReferenceProject(project);
    }
    loadProjectDocument(project)
        .then(() => {
            if (document.body.dataset.project !== project) {
                return;
            }
            renderPageIndex(project, activeTargetSection);
            if (settings.scrollContent) {
                const scrollOptions = {
                    block: settings.scrollBlock,
                    focus: settings.focusTarget
                };
                if (settings.scrollProjectTitle || projectRootTarget) {
                    scrollToProjectTitle(project, activeTargetSection, scrollOptions);
                } else {
                    scrollToSection(activeTargetSection, scrollOptions);
                }
            } else {
                queueScrollSpy();
            }
        })
        .catch(() => {
            if (document.body.dataset.project === project) {
                hidePageIndex();
                queueScrollSpy();
            }
        });
}

function refreshActiveLink(nextActiveSectionId) {
    const activeId = nextActiveSectionId || decodeURIComponent(window.location.hash.slice(1));
    const project = projectFromSectionId(activeId) || document.body.dataset.project;
    const sidebarActiveId = sidebarSectionIdForActive(project, activeId);
    if (activeLink && activeLink.dataset.section !== sidebarActiveId) {
        activeLink.classList.remove("active");
        activeLink = undefined;
    }
    if (!activeId) {
        refreshPageIndex("");
        return;
    }
    const nextLink = projectSections.get(project)?.section.querySelector(".toc a[href='#" + CSS.escape(sidebarActiveId) + "']");
    if (nextLink) {
        nextLink.classList.add("active");
        activeLink = nextLink;
        activeSectionId = activeId;
        refreshPageIndex(activeId);
        let parent = nextLink.parentElement;
        while (parent) {
            if (parent.tagName === "DETAILS") {
                parent.open = true;
            }
            parent = parent.parentElement;
        }
    } else {
        refreshPageIndex(activeId);
    }
}

function bindProjectOptions() {
    refreshProjectSections();
    projectOptions.forEach((summary) => {
        if (summary.dataset.projectOptionBound === "true") {
            return;
        }
        summary.dataset.projectOptionBound = "true";
        const project = summary.closest("[data-project-nav]")?.dataset.projectNav;
        summary.addEventListener("mouseenter", () => prefetchProjectDocument(project));
        summary.addEventListener("focus", () => prefetchProjectDocument(project));
        summary.addEventListener("click", (event) => {
            event.preventDefault();
            const section = summary.closest("[data-project-nav]");
            if (section.open && document.body.dataset.project === section.dataset.projectNav) {
                section.open = false;
                return;
            }
            setProject(section.dataset.projectNav, {
                updateHash: true,
                forceHash: true,
                scrollContent: true,
                scrollProjectTitle: true
            });
        });
    });
}

document.querySelectorAll("[data-overview-doc-link]").forEach((link) => {
    const targetProject = projectFromSectionId(decodeURIComponent(link.hash.slice(1)));
    link.addEventListener("mouseenter", () => prefetchProjectDocument(targetProject));
    link.addEventListener("focus", () => prefetchProjectDocument(targetProject));
});

projectCards.forEach((card) => {
    const targetProject = projectFromSectionId(card.dataset.projectCardTarget) || card.dataset.projectCard;
    card.addEventListener("mouseenter", () => prefetchProjectDocument(targetProject));
    card.addEventListener("focus", () => prefetchProjectDocument(targetProject));
    card.addEventListener("keydown", (event) => {
        if (event.key !== "Enter" && event.key !== " ") {
            return;
        }
        if (isInteractiveCardTarget(event.target, card)) {
            return;
        }
        event.preventDefault();
        openProjectCard(card);
    });
});

document.addEventListener("click", (event) => {
    const copyButton = event.target.closest("[data-copy-code]");
    if (copyButton) {
        event.preventDefault();
        copyModernCodeBlock(copyButton);
        return;
    }
    if (event.target.closest("[data-search-backdrop]")) {
        event.preventDefault();
        closeSearchResults();
        searchTrigger?.focus();
        return;
    }
    const searchScopeButton = event.target.closest("[data-search-scope]");
    if (searchScopeButton) {
        event.preventDefault();
        setSearchScope(searchScopeButton.dataset.searchScope);
        return;
    }
    if (clickIsOutsideOpenSidebar(event)) {
        closeSidebar();
    }
    const projectCard = event.target.closest("[data-project-card]");
    if (projectCard && !isInteractiveCardTarget(event.target, projectCard)) {
        event.preventDefault();
        openProjectCard(projectCard);
        return;
    }
    const searchResult = event.target.closest("[data-search-result]");
    if (searchResult) {
        closeSearchResults();
        searchInput?.blur();
        if (searchResult.dataset.searchReferenceUrl) {
            event.preventDefault();
            const project = searchResult.dataset.searchProject;
            setProject(project, {
                sectionId: firstSections[project],
                updateHash: true,
                forceHash: true,
                scrollContent: true,
                scrollProjectTitle: true,
                scrollBlock: "center",
                focusTarget: true
            });
            const article = projectSections.get(project)?.article || projectArticles.get(project);
            const referenceButton = article?.querySelector("[data-reference-open][data-reference-kind='" + CSS.escape(searchResult.dataset.searchReferenceKind || "configuration") + "']");
            if (referenceButton) {
                openReference(referenceButton, {
                    url: searchResult.dataset.searchReferenceUrl,
                    title: searchResult.dataset.searchReferenceTitle || referenceButton.dataset.referenceTitle,
                    projectName: referenceButton.dataset.referenceProjectName
                });
            }
            closeSidebar();
            return;
        }
    } else if (!searchContainsTarget(event.target)) {
        closeSearchResults();
    }
    const referenceSwitch = event.target.closest("[data-reference-switch-kind]");
    if (referenceSwitch) {
        event.preventDefault();
        const article = projectSections.get(activeReferenceProject)?.article || projectArticles.get(activeReferenceProject);
        const referenceButton = article?.querySelector("[data-reference-open][data-reference-kind='" + CSS.escape(referenceSwitch.dataset.referenceSwitchKind || "") + "']");
        if (referenceButton) {
            openReference(referenceButton);
        }
        return;
    }
    const referenceTrigger = event.target.closest("[data-reference-open]");
    if (referenceTrigger) {
        event.preventDefault();
        openReference(referenceTrigger);
        return;
    }
    if (event.target.closest("[data-reference-close]")) {
        event.preventDefault();
        closeReference();
        return;
    }
    if (event.target.closest("[data-reference-expand]")) {
        event.preventDefault();
        setReferenceExpanded(!document.body.classList.contains("reference-expanded"));
        return;
    }
    const summaryLink = event.target.closest("summary a");
    if (summaryLink) {
        event.stopPropagation();
    }
    const hashLink = event.target.closest("a[href^='#']");
    if (!hashLink) {
        return;
    }
    const targetId = decodeURIComponent(hashLink.hash.slice(1));
    if (!targetId || targetId === overviewHash) {
        event.preventDefault();
        setOverview({
            updateHash: true,
            forceHash: true,
            scrollContent: true
        });
        closeSidebar();
        return;
    }
    const targetProject = projectFromSectionId(targetId);
    if (targetProject) {
        event.preventDefault();
        const fromSearch = Boolean(hashLink.closest("[data-search-result]"));
        const projectRootTarget = isProjectRootSection(targetId, targetProject);
        setProject(targetProject, {
            sectionId: targetId,
            updateHash: true,
            forceHash: true,
            scrollContent: true,
            scrollBlock: fromSearch && !projectRootTarget ? "center" : "start",
            focusTarget: fromSearch && !projectRootTarget,
            scrollProjectTitle: projectRootTarget || Boolean(hashLink.closest("[data-overview-doc-link], [data-search-project-link]"))
        });
        closeSidebar();
        window.setTimeout(queueScrollSpy, 0);
    }
});

sidebarToggle?.addEventListener("click", () => {
    const open = !document.body.classList.contains("sidebar-open");
    document.body.classList.toggle("sidebar-open", open);
    sidebarToggle.setAttribute("aria-expanded", String(open));
});

sidebarCollapse?.addEventListener("click", () => {
    const collapsed = !document.body.classList.contains("sidebar-collapsed");
    document.body.classList.toggle("sidebar-collapsed", collapsed);
    sidebarCollapse.setAttribute("aria-expanded", String(!collapsed));
    const label = collapsed ? "Expand sidebar" : "Collapse sidebar";
    sidebarCollapse.setAttribute("aria-label", label);
    sidebarCollapse.setAttribute("title", label);
    if (sidebarCollapseLabel) {
        sidebarCollapseLabel.textContent = label;
    }
});

themeSwitcher?.addEventListener("click", () => switchTheme());

searchTrigger?.addEventListener("click", () => {
    openSearchDialog(true);
});
searchInput?.addEventListener("input", queueSearch);
searchInput?.addEventListener("focus", () => {
    setSearchOpen(true);
    if (searchInput.value.trim().length >= 2) {
        queueSearch();
    } else {
        renderSearchPrompt();
    }
});
searchRoot?.addEventListener("focusin", updateSearchUiState);
searchRoot?.addEventListener("focusout", () => {
    window.requestAnimationFrame(updateSearchUiState);
});
searchInput?.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
        closeSearchResults();
        searchInput.blur();
        searchTrigger?.focus();
        return;
    }
    if (event.key === "ArrowDown") {
        event.preventDefault();
        setSearchActive(searchActiveIndex + 1);
        return;
    }
    if (event.key === "ArrowUp") {
        event.preventDefault();
        setSearchActive(searchActiveIndex <= 0 ? 999 : searchActiveIndex - 1);
        return;
    }
    if (event.key === "Enter" && searchActiveIndex >= 0) {
        const result = searchResults?.querySelectorAll("[data-search-result]")[searchActiveIndex];
        if (result) {
            event.preventDefault();
            result.click();
        }
    }
});
searchClear?.addEventListener("click", () => {
    if (searchInput) {
        searchInput.value = "";
        searchInput.focus();
    }
    setSearchOpen(true);
    renderSearchPrompt();
    updateSearchUiState();
});

window.addEventListener("keydown", (event) => {
    const target = event.target instanceof Element ? event.target : undefined;
    const editing = Boolean(target?.closest("input, textarea, select, [contenteditable='true']"));
    if ((event.key === "/" && !event.metaKey && !event.ctrlKey && !event.altKey && !editing)
        || (event.key.toLowerCase() === "k" && (event.metaKey || event.ctrlKey))) {
        event.preventDefault();
        openSearchDialog(true);
        return;
    }
    if (event.key === "Escape" && searchDialog && !searchDialog.hidden) {
        closeSearchResults();
        searchTrigger?.focus();
        return;
    }
    if (event.key === "Escape" && referencePanel && !referencePanel.hidden) {
        closeReference();
    }
});

window.addEventListener("hashchange", () => {
    const sectionId = decodeURIComponent(window.location.hash.slice(1));
    if (!sectionId || sectionId === overviewHash) {
        setOverview(false);
        return;
    }
    const targetProject = projectFromSectionId(sectionId);
    if (!targetProject) {
        setOverview(false);
        return;
    }
    setProject(targetProject, {
        sectionId,
        scrollContent: true,
        scrollProjectTitle: isProjectRootSection(sectionId, targetProject)
    });
});
window.addEventListener("scroll", queueScrollSpy, { passive: true });
window.addEventListener("resize", queueScrollSpy);

applyTheme(preferredTheme());
if (window.matchMedia) {
    const colorScheme = window.matchMedia("(prefers-color-scheme: dark)");
    colorScheme.addEventListener("change", () => {
        if (!themeManuallySelected) {
            applyTheme(preferredTheme());
        }
    });
}
function initializeRoute() {
    const initialSectionId = decodeURIComponent(window.location.hash.slice(1));
    if (!initialSectionId || initialSectionId === overviewHash) {
        setOverview(false);
    } else {
        const initialProject = projectFromSectionId(initialSectionId);
        if (initialProject) {
            setProject(initialProject, {
                sectionId: initialSectionId,
                scrollContent: true,
                scrollProjectTitle: isProjectRootSection(initialSectionId, initialProject)
            });
        } else {
            setOverview(false);
        }
    }
    if (!document.body.classList.contains("overview-active")) {
        queueScrollSpy();
    }
}

loadSidebarMenu().catch(() => {
    // The page can still open project documents from overview cards and search results.
}).finally(initializeRoute);
updateSearchUiState();
