function copyText(element) {
    let range;
    let selection;

    if (document.body.createTextRange) {
        range = document.body.createTextRange();
        range.moveToElementText(element);
        range.select();
    } else if (window.getSelection) {
        selection = window.getSelection();
        range = document.createRange();
        range.selectNodeContents(element);
        selection.removeAllRanges();
        selection.addRange(range);
    }

    document.execCommand("copy");
}

window.copyToClipboard = function copyToClipboard(element) {
    const source = element.parentNode?.previousElementSibling;
    if (source) {
        copyText(source);
    }
};

function modernCodeCopyIcon() {
    return "<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\" focusable=\"false\"><rect width=\"14\" height=\"14\" x=\"8\" y=\"8\" rx=\"2\" ry=\"2\"></rect><path d=\"M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2\"></path></svg><span class=\"visually-hidden\">Copy code</span>";
}

function hasCodeLanguage(code) {
    if (code?.dataset?.lang) {
        return true;
    }
    return Array.from(code?.classList || []).some((className) => className.startsWith("language-"));
}

function codeLanguageKey(language) {
    const value = String(language || "").trim().toLowerCase();
    if (value === "gradle-groovy" || value === "gradle-kotlin") {
        return "gradle";
    }
    if (value === "pom") {
        return "maven";
    }
    if (value === "groovy-config") {
        return "groovy";
    }
    if (value === "json-config") {
        return "json";
    }
    if (value === "yml") {
        return "yaml";
    }
    if (value === "conf") {
        return "hocon";
    }
    if (["props", "property"].includes(value)) {
        return "properties";
    }
    if (["bash", "console", "sh", "shell", "zsh"].includes(value)) {
        return "shell";
    }
    if (["plaintext", "txt"].includes(value)) {
        return "text";
    }
    if (value === "js") {
        return "javascript";
    }
    if (value === "ts") {
        return "typescript";
    }
    return value;
}

function isDependencySnippet(code) {
    const language = codeLanguageKey(languageFromCodeElement(code));
    if (["gradle", "maven"].includes(language)) {
        return true;
    }
    const text = code?.textContent || "";
    if (["xml", "text"].includes(language) && /<(dependency|dependencyManagement|annotationProcessorPaths)\b|<\/dependency>|<(groupId|artifactId)>/.test(text)) {
        return true;
    }
    if (["groovy", "kotlin", "java", "text"].includes(language) && /\b(api|implementation|compileOnly|runtimeOnly|annotationProcessor|testImplementation|ksp|kapt)\s*\(/.test(text)) {
        return true;
    }
    return false;
}

function codeLanguageLabel(language) {
    const value = String(language || "").trim().toLowerCase();
    const labels = {
        "bash": "Shell",
        "conf": "Config",
        "console": "Shell",
        "gradle": "Gradle",
        "gradle-groovy": "Gradle (Groovy)",
        "gradle-kotlin": "Gradle (Kotlin)",
        "graphql": "GraphQL",
        "groovy": "Groovy",
        "groovy-config": "Groovy",
        "hocon": "HOCON",
        "html": "HTML",
        "java": "Java",
        "javascript": "JavaScript",
        "js": "JavaScript",
        "json": "JSON",
        "json-config": "JSON",
        "kotlin": "Kotlin",
        "maven": "Maven",
        "plaintext": "Text",
        "pom": "Maven",
        "protobuf": "Protocol Buffers",
        "properties": "Properties",
        "python": "Python",
        "sh": "Shell",
        "shell": "Shell",
        "sql": "SQL",
        "text": "Text",
        "ts": "TypeScript",
        "toml": "TOML",
        "typescript": "TypeScript",
        "xml": "XML",
        "yaml": "YAML",
        "yml": "YAML",
        "zsh": "Shell"
    };
    if (labels[value]) {
        return labels[value];
    }
    return String(language || "")
        .split("-")
        .filter(Boolean)
        .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
        .join(" ");
}

function codeLanguageIcon(language) {
    const key = codeLanguageKey(language);
    const generatedIcon = codeLanguageIcons[key];
    if (generatedIcon) {
        const svgAttributes = generatedIcon.fill
            ? "fill=\"currentColor\""
            : "fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"";
        const fillClass = generatedIcon.fill ? " docs-code-language-icon-fill" : "";
        return "<span class=\"docs-code-language-icon docs-code-language-icon-" + key + fillClass + "\" aria-hidden=\"true\"><svg viewBox=\"" + generatedIcon.viewBox + "\" " + svgAttributes + " focusable=\"false\">" + generatedIcon.body + "</svg></span>";
    }
    return "";
}

function codeLanguageTabHtml(language, label) {
    return codeLanguageIcon(language) + "<span class=\"docs-code-language-text\">" + escapeHtml(label) + "</span>";
}

function upgradeCodeBlocks(root) {
    root.querySelectorAll(".listingblock:not([data-code-block])").forEach((block) => {
        const code = block.querySelector("pre code");
        const content = block.querySelector(".content");
        if (!code || !content) {
            return;
        }
        const title = block.querySelector(":scope > .title");
        const multiLanguageSample = block.classList.contains("multi-language-sample");
        block.classList.add("docs-code-block");
        block.dataset.codeBlock = "";
        if (title?.textContent?.trim()) {
            const titleElement = document.createElement("div");
            titleElement.className = "docs-code-title";
            titleElement.innerHTML = title.innerHTML.trim();
            if (multiLanguageSample) {
                block.insertBefore(titleElement, content);
            } else {
                block.parentNode?.insertBefore(titleElement, block);
            }
            title.remove();
        }
        if (!hasCodeLanguage(code)) {
            code.classList.add("language-plaintext");
            code.dataset.lang = "text";
        }
        if (isDependencySnippet(code)) {
            block.classList.add("docs-code-dependency-snippet");
        }
        const copy = document.createElement("button");
        copy.className = "docs-code-copy";
        copy.type = "button";
        copy.dataset.copyCode = "";
        copy.title = "Copy code";
        copy.setAttribute("aria-label", "Copy code");
        copy.innerHTML = modernCodeCopyIcon();
        block.insertBefore(copy, content);
        content.classList.add("docs-code-content");
    });
}

function copyModernCodeBlock(button) {
    const block = button.closest("[data-code-block]");
    const code = block?.querySelector("pre code");
    if (!code) {
        return;
    }
    const value = code.textContent || "";
    const copied = () => {
        button.classList.add("copied");
        button.setAttribute("aria-label", "Copied");
        button.title = "Copied";
        window.setTimeout(() => {
            button.classList.remove("copied");
            button.setAttribute("aria-label", "Copy code");
            button.title = "Copy code";
        }, 1200);
    };
    if (navigator.clipboard?.writeText) {
        navigator.clipboard.writeText(value).then(copied).catch(() => {
            copyText(code);
            copied();
        });
    } else {
        copyText(code);
        copied();
    }
}

function multiLanguageSamplesForSelector(selector) {
    const samples = [];
    let sample = selector.nextElementSibling;
    while (sample?.classList?.contains("multi-language-sample")) {
        samples.push(sample);
        sample = sample.nextElementSibling;
    }
    return samples;
}

function languageFromCodeElement(code) {
    if (!code) {
        return "";
    }
    if (code.dataset?.lang) {
        return code.dataset.lang;
    }
    const languageClass = Array.from(code.classList || [])
        .find((className) => className.startsWith("language-"));
    return languageClass ? languageClass.substring("language-".length) : "";
}

function languageForSample(sample) {
    const language = sample.getAttribute("data-lang") || languageFromCodeElement(sample.querySelector("pre code"));
    if (language) {
        sample.setAttribute("data-lang", language);
    }
    return language;
}

function multiLanguageSampleGroups(root) {
    const groups = [];
    root.querySelectorAll(".multi-language-sample").forEach((sample) => {
        if (sample.previousElementSibling?.classList?.contains("multi-language-sample")) {
            return;
        }
        const group = [sample];
        let next = sample.nextElementSibling;
        while (next?.classList?.contains("multi-language-sample")) {
            group.push(next);
            next = next.nextElementSibling;
        }
        if (group.length > 1) {
            groups.push(group);
        }
    });
    return groups;
}

function ensureMultiLanguageSelectors(root) {
    multiLanguageSampleGroups(root).forEach((samples) => {
        let selector = samples[0].previousElementSibling;
        if (!selector?.classList?.contains("multi-language-selector")) {
            selector = document.createElement("div");
            selector.className = "multi-language-selector";
            samples[0].parentNode?.insertBefore(selector, samples[0]);
        }
        if (!selector.dataset.docsTabsId) {
            selector.dataset.docsTabsId = "multi-language-tabs-" + (++multiLanguageSelectorId);
        }
        const languages = [];
        samples.forEach((sample) => {
            const language = languageForSample(sample);
            if (language && !languages.includes(language)) {
                languages.push(language);
            }
        });
        selector.replaceChildren(...languages.map((language) => {
            const option = document.createElement("button");
            option.className = "language-option";
            option.type = "button";
            option.dataset.lang = language;
            option.setAttribute("data-lang", language);
            option.setAttribute("role", "button");
            option.textContent = codeLanguageLabel(language);
            option.addEventListener("click", () => {
                setMultiLanguageSelectorLanguage(selector, language);
            });
            return option;
        }));
        const selectedLanguage = selector.querySelector(".language-option.selected")?.getAttribute("data-lang")
            || samples.find((sample) => !sample.classList.contains("hidden"))?.getAttribute("data-lang")
            || languages[0];
        setMultiLanguageSelectorLanguage(selector, selectedLanguage);
    });
}

function syncMultiLanguageTabs(root) {
    root.querySelectorAll(".docs-code-tabs-multi[data-source-selector]").forEach((tabs) => {
        const selector = document.querySelector("[data-docs-tabs-id=\"" + tabs.dataset.sourceSelector + "\"]");
        if (!selector) {
            return;
        }
        tabs.querySelectorAll("[data-lang]").forEach((tab) => {
            const source = Array.from(selector.querySelectorAll(".language-option"))
                .find((option) => option.getAttribute("data-lang") === tab.getAttribute("data-lang"));
            tab.classList.toggle("selected", Boolean(source?.classList.contains("selected")));
            tab.setAttribute("aria-selected", String(Boolean(source?.classList.contains("selected"))));
        });
    });
}

function setMultiLanguageSelectorLanguage(selector, language) {
    const samples = multiLanguageSamplesForSelector(selector);
    if (!samples.length) {
        return;
    }
    let selectedLanguage = language;
    let visibleSample = samples.find((sample) => sample.getAttribute("data-lang") === selectedLanguage);
    if (!visibleSample) {
        visibleSample = samples[0];
        selectedLanguage = visibleSample.getAttribute("data-lang");
    }
    selector.querySelectorAll(".language-option").forEach((option) => {
        option.classList.toggle("selected", option.getAttribute("data-lang") === selectedLanguage);
    });
    samples.forEach((sample) => {
        sample.classList.toggle("hidden", sample !== visibleSample);
    });
    syncMultiLanguageTabs(selector.parentElement || document);
}

function integrateMultiLanguageTabs(root) {
    root.querySelectorAll(".multi-language-selector").forEach((selector) => {
        const samples = multiLanguageSamplesForSelector(selector);
        if (samples.length < 2) {
            return;
        }
        const titleHtml = samples.map((sample) => sample.querySelector(":scope > .docs-code-title"))
            .find((title) => title?.textContent?.trim())
            ?.innerHTML
            ?.trim();
        samples.forEach((sample) => {
            sample.querySelector(":scope > .docs-code-title")?.remove();
        });
        if (titleHtml) {
            let titleElement = selector.previousElementSibling;
            if (!titleElement?.classList?.contains("docs-code-title")) {
                titleElement = document.createElement("div");
                titleElement.className = "docs-code-title";
                selector.parentNode?.insertBefore(titleElement, selector);
            }
            titleElement.innerHTML = titleHtml;
        }
        if (!selector.dataset.docsTabsId) {
            selector.dataset.docsTabsId = "multi-language-tabs-" + (++multiLanguageSelectorId);
        }
        selector.hidden = true;
        selector.setAttribute("aria-hidden", "true");
        const options = Array.from(selector.querySelectorAll(".language-option"))
            .map((option) => ({
                language: option.getAttribute("data-lang"),
                label: option.textContent.trim()
            }))
            .filter((option) => option.language && option.label);
        samples.forEach((sample) => {
            let toolbar = sample.querySelector(":scope > .docs-code-toolbar");
            if (!toolbar) {
                toolbar = document.createElement("div");
                toolbar.className = "docs-code-toolbar";
                const copy = sample.querySelector(":scope > .docs-code-copy");
                const content = sample.querySelector(":scope > .docs-code-content");
                sample.insertBefore(toolbar, content);
                if (copy) {
                    toolbar.appendChild(copy);
                }
            }
            let tabs = toolbar.querySelector(":scope > .docs-code-tabs");
            if (!tabs) {
                tabs = document.createElement("div");
                tabs.className = "docs-code-tabs";
                toolbar.insertBefore(tabs, toolbar.firstChild);
            }
            tabs.classList.add("docs-code-tabs-multi");
            tabs.dataset.sourceSelector = selector.dataset.docsTabsId;
            tabs.setAttribute("role", "tablist");
            tabs.replaceChildren(...options.map((option) => {
                const tab = document.createElement("button");
                tab.className = "docs-code-language language-option";
                tab.type = "button";
                tab.dataset.lang = option.language;
                tab.setAttribute("role", "tab");
                tab.innerHTML = codeLanguageTabHtml(option.language, option.label);
                tab.addEventListener("click", () => {
                    setMultiLanguageSelectorLanguage(selector, option.language);
                });
                return tab;
            }));
        });
    });
    syncMultiLanguageTabs(root);
}

function escapeHtml(value) {
    return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll("\"", "&quot;");
}

function splitCamelCase(value) {
    return String(value || "")
        .replace(/([A-Z]+)([A-Z][a-z])/g, "$1 $2")
        .replace(/([a-z0-9])([A-Z])/g, "$1 $2");
}

function normalizeSearchText(value) {
    return splitCamelCase(value)
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, " ")
        .trim();
}

function searchTokens(value) {
    const tokens = new Set(normalizeSearchText(value)
        .split(/\s+/)
        .filter((token) => token.length > 1));
    const compact = String(value || "")
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, "");
    if (compact.length > 1 && compact.length <= 40) {
        tokens.add(compact);
    }
    return Array.from(tokens).slice(0, 6);
}

