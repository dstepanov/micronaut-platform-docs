<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Micronaut Platform Docs {{platform.displayVersion}}</title>
    <link rel="stylesheet" href="{{assetPath}}/site.css">
</head>
<body class="body js overview-active" id="docs" data-project="">
    <div class="app-shell">
        <aside id="sidebar" class="sidebar">
            <div class="sidebar-header">
                <a class="sidebar-brand" href="#{{overviewSectionId}}" aria-label="Micronaut Platform Docs">
                    <span class="sidebar-logo-wrap" aria-hidden="true">
                        <img class="sidebar-logo sidebar-logo-light" src="{{assetPath}}/logos/micronaut-horizontal-black.svg" alt="">
                        <img class="sidebar-logo sidebar-logo-dark" src="{{assetPath}}/logos/micronaut-horizontal-white.svg" alt="">
                    </span>
                </a>
            </div>
            <nav class="sidebar-content toc" aria-label="Projects">
                <section class="sidebar-group">
                    <div class="sidebar-group-heading">
                        <span class="sidebar-group-label">Projects</span>
                        <button class="project-filter-toggle" type="button" aria-controls="project-filter" aria-expanded="false" title="Filter projects" aria-label="Filter projects" data-project-filter-toggle>
                            {{{icons.search}}}
                        </button>
                    </div>
                    <div id="project-filter" class="project-filter" data-project-filter hidden>
                        <div class="project-filter-field">
                            {{{icons.search}}}
                            <input id="project-filter-input" type="search" placeholder="Filter projects" aria-label="Filter projects" autocomplete="off" spellcheck="false" data-project-filter-input>
                            <button class="project-filter-clear" type="button" title="Clear project filter" aria-label="Clear project filter" data-project-filter-clear hidden>
                                {{{icons.x}}}
                            </button>
                        </div>
                        <div class="project-filter-empty" data-project-filter-empty hidden>No projects found</div>
                    </div>
                    <div class="sidebar-projects" data-sidebar-menu data-menu-url="{{sidebarMenuPath}}" data-menu-script-url="{{sidebarMenuScriptPath}}" aria-busy="true">
                        <div class="sidebar-menu-loading" data-sidebar-menu-loading aria-label="Loading projects">
                            <span></span>
                            <span></span>
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                    </div>
                </section>
            </nav>
            <div class="sidebar-rail" aria-hidden="true"></div>
        </aside>
        <div class="app-main">
            <header class="topbar">
                <button class="sidebar-collapse" type="button" aria-controls="sidebar" aria-expanded="true" title="Collapse sidebar" aria-label="Collapse sidebar">
                    {{{icons.panelLeft}}}
                    <span class="visually-hidden" data-sidebar-collapse-label>Collapse sidebar</span>
                </button>
                <span class="topbar-separator" aria-hidden="true"></span>
                <nav class="topbar-title" aria-label="Breadcrumb">
                    <a href="#{{overviewSectionId}}">Micronaut Platform Docs</a>
                    <span aria-hidden="true">/</span>
                    <span class="topbar-version" title="{{platform.revision}}" data-platform>
                        {{{icons.gitBranch}}}
                        <span>{{platform.displayVersion}}</span>
                    </span>
                </nav>
                <div class="site-search" data-search>
                    <button class="site-search-trigger" type="button" aria-haspopup="dialog" aria-expanded="false" aria-controls="site-search-dialog" data-search-trigger>
                        {{{icons.search}}}
                        <span class="site-search-trigger-label">Search projects, classes, properties, docs...</span>
                        <kbd class="site-search-shortcut" aria-hidden="true">⌘K</kbd>
                    </button>
                </div>
                <div class="topbar-actions">
                    <button id="theme-switcher" class="theme-toggle" type="button" title="Switch to dark theme" aria-label="Switch to dark theme" aria-pressed="false" data-theme-switcher>
                        <span class="theme-icon theme-icon-moon">{{{icons.moon}}}</span>
                        <span class="theme-icon theme-icon-sun">{{{icons.sun}}}</span>
                    </button>
                </div>
                <button class="sidebar-toggle" type="button" aria-controls="sidebar" aria-expanded="false" title="Open sidebar" aria-label="Open sidebar">
                    {{{icons.menu}}}
                </button>
            </header>
            <div class="site-search-backdrop" data-search-backdrop hidden></div>
            <div id="site-search-dialog" class="site-search-panel" role="dialog" aria-modal="true" aria-label="Search platform docs" data-search-dialog hidden>
                <div class="site-search-dialog-field" data-search-field>
                    {{{icons.search}}}
                    <input type="search" placeholder="Search projects, classes, properties, docs..." aria-label="Search platform docs" aria-controls="site-search-results" aria-expanded="false" autocomplete="off" spellcheck="false" data-search-input>
                    <button class="site-search-clear" type="button" title="Clear search" aria-label="Clear search" data-search-clear hidden>
                    {{{icons.x}}}
                    </button>
                </div>
                <div class="site-search-panel-heading">
                    <span>Search everything</span>
                    <small>Projects, guide sections, API classes, configuration properties, and repositories.</small>
                </div>
                <div class="site-search-scopes" role="tablist" aria-label="Search scope">
                    <button class="site-search-scope active" type="button" role="tab" aria-selected="true" data-search-scope="all">All</button>
                    <button class="site-search-scope" type="button" role="tab" aria-selected="false" data-search-scope="projects">Projects</button>
                    <button class="site-search-scope" type="button" role="tab" aria-selected="false" data-search-scope="docs">Docs</button>
                    <button class="site-search-scope" type="button" role="tab" aria-selected="false" data-search-scope="config">Properties</button>
                    <button class="site-search-scope" type="button" role="tab" aria-selected="false" data-search-scope="api" title="API classes and Javadoc">Classes</button>
                    <button class="site-search-scope" type="button" role="tab" aria-selected="false" data-search-scope="repositories">Repos</button>
                </div>
                <div id="site-search-results" class="site-search-results" role="listbox" data-search-results hidden></div>
            </div>
            <main class="content" id="content">
                <section class="overview-page" id="{{overviewSectionId}}" data-overview tabindex="-1">
                    <header class="overview-header">
                        <p class="overview-description">Micronaut Framework is a modern JVM framework for modular applications and services with fast startup, low memory use, and compile-time dependency injection. These platform docs collect the core framework and companion modules in one place for aligned versions, guides, APIs, and configuration references.</p>
                    </header>
                    <div class="project-category-list" aria-label="Micronaut modules">
{{#each categories}}
                        <section class="project-category" data-project-category="{{slug}}">
                            <header class="project-category-header">
                                <div class="project-category-title">
                                    <span class="project-category-icon" aria-hidden="true">{{{icon}}}</span>
                                    <div>
                                        <h2>{{name}}</h2>
{{#if description}}
                                        <p>{{description}}</p>
{{/if}}
                                    </div>
                                </div>
                            </header>
                            <div class="project-card-grid">
{{#each documents}}
                        <article class="project-card" data-project-card="{{slug}}" data-project-card-target="{{slug}}" role="link" tabindex="0" aria-label="Open {{displayName}} documentation">
                            <div class="project-card-header">
                                <span class="project-card-icon" aria-hidden="true">{{{projectIcon}}}</span>
                                <div>
                                    <h3>{{displayName}}</h3>
                                    <p class="project-card-short-description">{{shortDescription}}</p>
                                </div>
                            </div>
                            <p class="project-card-long-description">{{longDescription}}</p>
                            <footer class="project-card-footer">
                                <div class="project-card-links">
                                    <a href="#{{slug}}" data-overview-doc-link aria-label="Open {{displayName}} docs">
                                        {{{@root.icons.fileText}}}
                                        <span>Docs</span>
                                    </a>
                                    <a href="{{repositoryUrl}}" target="_blank" rel="noopener" aria-label="Open {{displayName}} GitHub repository">
                                        {{{@root.icons.github}}}
                                        <span>GitHub</span>
                                    </a>
                                </div>
{{#if version}}
                                <small class="project-card-version">{{version}}</small>
{{/if}}
                            </footer>
                        </article>
{{/each}}
                            </div>
                        </section>
{{/each}}
                    </div>
                </section>
{{#each documents}}
            <article id="{{slug}}" class="guide-document docs-content" data-project="{{slug}}" data-document-url="{{documentPath}}" data-document-script-url="{{documentScriptPath}}" aria-busy="false"{{#unless selected}} hidden{{/unless}}>
                <div class="document-meta">
                    <div class="document-meta-row document-meta-primary">
                        <a href="{{repositoryUrl}}" aria-label="{{displayName}} GitHub repository">
                            {{{../icons.github}}}
                            <span>GitHub repository</span>
                        </a>
{{#if version}}
                        <span><strong>Version</strong>{{version}}</span>
{{/if}}
                        <span>{{{../icons.gitBranch}}}<strong>Branch</strong>{{branch}}</span>
                    </div>
{{#if hasReferenceLinks}}
                    <div class="document-meta-row document-meta-references">
{{#if apiReferencePath}}
                        <button type="button" aria-pressed="false" aria-label="Open API for {{displayName}}" title="Open API" data-reference-open data-reference-kind="api" data-reference-project="{{slug}}" data-reference-project-name="{{displayName}}" data-reference-title="API" data-reference-url="{{apiReferencePath}}">
                            {{{../icons.braces}}}
                            <span>API</span>
                        </button>
{{/if}}
{{#if configurationReferencePath}}
                        <button type="button" aria-pressed="false" aria-label="Open configuration reference for {{displayName}}" title="Open configuration reference" data-reference-open data-reference-kind="configuration" data-reference-project="{{slug}}" data-reference-project-name="{{displayName}}" data-reference-title="Configuration reference" data-reference-url="{{configurationReferencePath}}">
                            {{{../icons.slidersHorizontal}}}
                            <span>Configuration reference</span>
                        </button>
{{/if}}
                    </div>
{{/if}}
                </div>
                <div class="guide-document-loading" data-document-loading hidden aria-label="Loading documentation">
                    <div class="document-skeleton" aria-hidden="true">
                        <div class="document-skeleton-heading"></div>
                        <div class="document-skeleton-line document-skeleton-line-wide"></div>
                        <div class="document-skeleton-line"></div>
                        <div class="document-skeleton-line document-skeleton-line-short"></div>
                        <div class="document-skeleton-block"></div>
                        <div class="document-skeleton-line"></div>
                        <div class="document-skeleton-line document-skeleton-line-wide"></div>
                        <div class="document-skeleton-line document-skeleton-line-short"></div>
                    </div>
                </div>
                <div class="guide-document-error" data-document-error hidden>Documentation could not be loaded.</div>
                <div data-document-content></div>
            </article>
{{/each}}
            </main>
            <aside class="page-index" aria-label="On this page" data-page-index hidden>
                <div class="page-index-inner">
                    <div class="page-index-header">
                        <span>On this page</span>
                        <a class="page-index-top" href="#content" title="Back to top" aria-label="Back to top" data-page-index-top>
                            {{{icons.arrowUp}}}
                        </a>
                    </div>
                    <nav class="page-index-nav" aria-label="Current page sections" data-page-index-nav></nav>
                </div>
            </aside>
            <div class="reference-overlay" data-reference-overlay data-reference-close hidden></div>
            <aside class="reference-panel" role="dialog" aria-modal="true" aria-labelledby="reference-title" aria-label="Project reference" tabindex="-1" data-reference-panel hidden>
                <div class="reference-header">
                    <div class="reference-heading">
                        <strong id="reference-title" data-reference-title>Reference</strong>
                        <small data-reference-project-label></small>
                    </div>
                    <div class="reference-actions">
                        <button class="reference-action" type="button" title="Expand reference panel" aria-label="Expand reference panel" aria-pressed="false" data-reference-expand>
                            <span class="reference-expand-icon-default">{{{icons.maximize2}}}</span>
                            <span class="reference-expand-icon-expanded">{{{icons.minimize2}}}</span>
                        </button>
                        <a class="reference-action" href="#" target="_blank" rel="noopener" title="Open in new tab" aria-label="Open reference in new tab" data-reference-open-new>
                            {{{icons.externalLink}}}
                        </a>
                        <button class="reference-action" type="button" title="Close reference" aria-label="Close reference" data-reference-close>
                            {{{icons.x}}}
                        </button>
                    </div>
                    <div class="reference-switcher" role="tablist" aria-label="Reference type" data-reference-switcher hidden></div>
                </div>
                <iframe class="reference-frame" title="Project reference" loading="lazy" data-reference-frame></iframe>
            </aside>
        </div>
    </div>
    <script src="{{guideAssetPath}}/js/multi-language-sample.js"></script>
    <script src="{{assetPath}}/site.js"></script>
</body>
</html>
